namespace agent {
    // Status record exported to Kotlin
    record EngineStatus {
        boolean is_running;
        string last_log;
        string current_run_id;
    };

    // Error enum
    [Error]
    enum EngineError {
        "ConfigError",
        "NetworkError",
        "BookingFailed",
        "InternalError"
    };
};

// Interface for the booking agent
// Note: For uniffi 0.30.0, we use [TraitInterface] attribute in UDL
[TraitInterface]
interface BookingAgent {
    // Constructor
    constructor();

    // Get current status
    EngineStatus get_status();

    // Stop the current operation
    void stop();

    // Start a strike operation
    // Returns boolean indicating success/failure
    [Throws=EngineError]
    boolean start_strike(string config_json, string run_id);
};
